# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Session Configuration (in seconds)
NEXT_PUBLIC_SESSION_TIMEOUT=10800

# OTP Secret (generate with: openssl rand -hex 32)
OTP_SECRET=your-otp-secret-key

# SMTP Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Arcadia

# Agent Server Configuration
AGENT_SERVER_URL=http://localhost:4000
AGENT_SERVER_SECRET=your-agent-secret-key

# Cron Secret
CRON_SECRET=your-cron-secret-key
